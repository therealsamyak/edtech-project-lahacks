# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# ElevenLabs API key for text-to-speech and voice agent.
# Get one at https://elevenlabs.io/app/settings/api-keys
# For the local spike script: put it in .env.local (gitignored).
# For Convex actions in production: also set via `npx convex env set ELEVENLABS_API_KEY <key>`.
ELEVENLABS_API_KEY=

# Optional: ElevenLabs voice ID. Defaults to Rachel (21m00Tcm4TlvDq8ikWAM) if unset.
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=

# Optional: ElevenLabs Conversational AI agent ID. Required only for the Voice Agent feature.
# Create one at https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=
